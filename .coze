[project]
name = "MySQL管理平台"
requires = ["nodejs-24", "python-311"]

[dev]
build = ["bash", "-c", "echo '=== Installing Node dependencies ===' && cd frontend && pnpm install"]
run = ["bash", "-c", "echo '=== Starting MySQL Platform ===' && cd backend && pip3 install -q -r requirements.lock.txt 2>/dev/null; uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload"]

[deploy]
build = ["bash", "-c", "echo '=== Installing Node dependencies ===' && cd frontend && pnpm install && echo '=== Building frontend ===' && pnpm build"]
run = ["bash", "-c", "echo '=== Starting MySQL Platform ===' && pip3 install -q -r backend/requirements.lock.txt 2>/dev/null; cd backend && uvicorn app.main:app --host 0.0.0.0 --port 5000"]
