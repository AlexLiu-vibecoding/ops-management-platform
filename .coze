[project]
name = "MySQL管理平台"
requires = ["nodejs-24", "python-311"]

[dev]
build = ["bash", "-c", "pip install -r backend/requirements.txt && cd frontend && pnpm install"]
run = ["bash", "-c", "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload"]

[deploy]
build = ["bash", "-c", "cd backend && pip install -r requirements.txt && cd ../frontend && pnpm install && pnpm build"]
run = ["bash", "-c", "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 5000"]
