[project]
name = "MySQL管理平台"
entrypoint = "frontend"
requires = ["nodejs-24", "python-311"]

[dev]
build = [
    "bash", "-c", 
    "cd frontend && pnpm install && cd ../backend && pip install -r requirements.txt"
]
run = [
    "bash", "-c",
    "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 & cd frontend && pnpm dev"
]

[deploy]
build = [
    "bash", "-c",
    "cd backend && pip install -r requirements.txt && cd ../frontend && pnpm install && pnpm build"
]
run = [
    "bash", "-c",
    "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 5000"
]
