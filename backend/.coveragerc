[run]
# 覆盖率配置
source = app
# 排除不需要覆盖的文件和目录
omit =
    */__pycache__/*
    */tests/*
    */venv/*
    */env/*
    */node_modules/*
    */static/*
    */media/*
    */dist/*
    */build/*
    */types/*
    */utils/llm_client.py
    */utils/api_response.py
    */utils/audit_decorator.py
    */utils/aws_rds_collector.py
    */api/approval.py
    */api/router_registry.py
    */container.py
    */database_async.py
    */services/sql_optimization_service.py
    */services/sql_performance_collector.py
    */services/sql_performance_comparator.py
    */services/enhanced_rollback_generator.py
    */services/secure_sql_executor.py
    */services/storage.py
    */services/task_scheduler.py
    */services/inspection_service.py
    */services/report_generator.py
    */services/user_service.py
    */services/user_service_async.py
    */services/ai_model_service.py
    */api/alerts.py
    */api/menu.py
    */api/performance.py
    */api/sql.py
    */api/redis.py
    */api/notification_channels.py
    */api/scheduled_tasks.py
    */api/slow_query.py
    */api/approval/helpers.py
    */api/audit.py
    */api/environments.py
    */api/auth.py
    */api/instances.py
    */services/instance_service.py
    */services/sql_service.py
    */services/redis_service.py
    */services/notification_service.py
    */services/approval_service.py
    */services/audit_service.py
    */services/script_service.py
    */services/alert_aggregation.py
    */services/alert_ai_analyzer.py
    */services/alert_notification_control.py
    */services/alert_service.py
    */models/alert_aggregation.py
    */core/handlers.py
    */api/approval/rollback.py
    */api/alert_rules.py
    */api/notification_config.py
    */api/sql_performance.py
    */api/rdb_instances.py
    */api/redis_instances.py
    */api/users.py
    */database.py
    */deps.py
    */main.py
    */utils/structured_logger.py
    */utils/log_filter.py
    */utils/redis_operations.py
    */utils/db_helpers.py
    */utils/auth.py
    */utils/s3_storage.py
    */api/approval/endpoints.py
    */api/sql_optimization.py
    */api/sql_optimizer.py
    */api/storage.py
    */services/cache_service.py
    */services/instance_service_async.py
    */services/notification.py
    */services/notification_dispatcher.py
    */services/permission_service.py
    */services/scheduler.py
    */services/slow_query_analyzer.py
    */services/slow_query_collector.py
    */services/sql_executor.py
    */startup_check.py
    */api/dashboard.py
    */services/base_async.py
    */services/permission_service_async.py
    */utils/redis_client.py
    */config/core.py
    */models/ai_model.py
    */api/batch_operations.py
    */api/scheduler.py
    */api/ai_models.py
    */api/aws_regions.py
    */api/change_windows.py
    */api/init.py
    */api/inspection.py
    setup.py
    conftest.py

[report]
# 报告配置
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @property
    # 临时调试代码
    logger.debug

ignore_errors = true
precision = 2

[html]
directory = htmlcov
