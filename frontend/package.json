{
  "name": "mysql-platform-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --port 3000 --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .vue,.js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{vue,js,jsx,ts,tsx}\"",
    "lint:fix": "eslint src --ext .vue,.js,.jsx,.ts,.tsx --fix"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.2",
    "codemirror": "^5.65.16",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "1.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.69.5",
    "vite": "^5.0.10",
    "vitest": "1.6.0"
  }
}
