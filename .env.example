# ============================================
# 运维管理平台 - 环境配置示例
# 复制此文件为 .env 并修改配置
# ============================================

# ---------- 服务端口 ----------
PORT=5000

# ---------- 数据库配置（必填） ----------
# PostgreSQL (推荐)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 或 MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=ops_platform

# ---------- Redis 配置 (可选) ----------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# 安全配置（可选，已有默认值）
# ============================================
# 系统已内置默认密钥，可直接使用
# 如需自定义，取消下面的注释并修改

# JWT_SECRET_KEY=your-custom-jwt-key
# AES_KEY=your-custom-32-char-aes-key!
# PASSWORD_SALT=your-custom-salt
