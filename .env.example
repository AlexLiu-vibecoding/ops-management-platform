# ============================================
# OpsCenter 运维管理平台 - 环境配置示例
# ============================================
# 复制此文件为 .env 并根据环境修改配置
# 配置优先级：环境变量 > .env 文件 > 默认值

# ============================================
# 应用配置
# ============================================
APP_NAME=OpsCenter
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=false
# 项目域名（用于生成回调URL等）
APP_PROJECT_DOMAIN=

# ============================================
# 数据库配置（必填）
# ============================================
# 方式一：使用连接 URL（推荐）
# PostgreSQL: postgresql://user:password@host:port/database
# MySQL: mysql+pymysql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ops_platform

# 方式二：PostgreSQL 分离配置
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=ops_platform

# 方式三：MySQL 分离配置（兼容）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=ops_platform

# 数据库连接池配置（可选）
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600

# ============================================
# Redis 配置
# ============================================
# 方式一：使用连接 URL（推荐）
# REDIS_URL=redis://:password@host:port/db

# 方式二：分离配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis 连接池配置（可选）
# REDIS_POOL_SIZE=10
# REDIS_SOCKET_TIMEOUT=5

# ============================================
# 安全配置（生产环境必填！）
# ============================================
# ⚠️  生产环境请务必设置以下密钥！
# ⚠️  以下密钥应使用随机生成的强密码

# JWT 签名密钥（建议 32+ 字符）
JWT_SECRET_KEY=your-jwt-secret-key-change-me-in-production

# AES 加密密钥（必须 32 字符）
AES_KEY=your-32-character-aes-key-here!!

# 密码哈希盐值
PASSWORD_SALT=your-password-salt-change-me

# JWT 配置
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# ============================================
# 存储配置
# ============================================
# 存储类型: local, s3, oss
STORAGE_TYPE=local

# 本地存储路径
STORAGE_LOCAL_PATH=/app/data/sql_files

# 文件保留天数
STORAGE_FILE_RETENTION_DAYS=30

# 大文件阈值（字符数，默认 10MB）
STORAGE_FILE_SIZE_THRESHOLD=10000000

# AWS S3 配置（如使用 S3 存储）
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# 阿里云 OSS 配置（如使用 OSS 存储）
# STORAGE_OSS_BUCKET=your-bucket-name
# STORAGE_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# STORAGE_OSS_ACCESS_KEY=
# STORAGE_OSS_SECRET_KEY=

# ============================================
# AWS 配置（用于 RDS 监控等）
# ============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_RDS_ENABLED=false

# ============================================
# 通知配置
# ============================================
# 钉钉通知
# NOTIFICATION_DINGTALK_ENABLED=false
# NOTIFICATION_DINGTALK_WEBHOOK=
# NOTIFICATION_DINGTALK_SECRET=

# 邮件通知
# NOTIFICATION_EMAIL_ENABLED=false
# NOTIFICATION_EMAIL_SMTP_HOST=smtp.example.com
# NOTIFICATION_EMAIL_SMTP_PORT=587
# NOTIFICATION_EMAIL_SMTP_USER=
# NOTIFICATION_EMAIL_SMTP_PASSWORD=
# NOTIFICATION_EMAIL_FROM=noreply@example.com

# ============================================
# 监控配置
# ============================================
# APP_MONITOR_COLLECT_INTERVAL=60
# APP_SLOW_QUERY_COLLECT_INTERVAL=300
# APP_PERFORMANCE_DATA_RETENTION_DAYS=30
# APP_SNAPSHOT_RETENTION_DAYS=7

# ============================================
# 审批配置
# ============================================
# APP_APPROVAL_TIMEOUT_HOURS=48
