# ============================================
# 运维管理平台 - 环境配置示例
# 复制此文件为 .env 并修改配置
# ============================================

# ---------- 服务端口 ----------
PORT=5000

# ---------- 数据库配置 ----------
# PostgreSQL (推荐)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 或 MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=ops_platform

# ---------- Redis 配置 (可选) ----------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# 安全配置（必须修改！使用下面的命令生成随机值）
# ============================================

# ---------- JWT_SECRET_KEY ----------
# 用途：签名用户登录令牌，防止 Token 被伪造
# 要求：至少 32 个字符，越随机越好
# 风险：泄露后攻击者可伪造 Token 冒充任何用户
# 生成命令：openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters

# ---------- AES_KEY ----------
# 用途：加密存储数据库密码等敏感信息
# 要求：必须正好 32 个字符（不能多不能少）
# 风险：泄露后可解密所有存储的密码；更换后需重新保存所有密码
# 生成命令：openssl rand -base64 24 | head -c 32 && echo
AES_KEY=change-this-to-32-chars-key!!

# ---------- PASSWORD_SALT ----------
# 用途：用户密码加密时的盐值，防止彩虹表攻击
# 要求：任意字符串即可
# 风险：泄露后更容易破解用户密码；更换后所有用户需重置密码
# 生成命令：openssl rand -hex 16
PASSWORD_SALT=change-this-salt-value

# ============================================
# 快速生成命令（Linux/Mac）：
# JWT_SECRET_KEY: openssl rand -hex 32
# AES_KEY:         openssl rand -base64 24 | head -c 32 && echo
# PASSWORD_SALT:   openssl rand -hex 16
# ============================================
