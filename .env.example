# ============================================
# 运维管理平台 - 环境配置示例
# 复制此文件为 .env 并修改配置
# ============================================

# ---------- 服务端口 ----------
PORT=5000

# ---------- 数据库配置（必填） ----------
# PostgreSQL (推荐)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 或 MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=ops_platform

# ---------- Redis 配置 (可选) ----------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# 安全配置（可选，首次启动自动生成）
# ============================================
# 如果不设置，系统会在首次启动时自动生成随机密钥并保存到 .env 文件
# 生产环境建议手动设置，并妥善保管

# JWT_SECRET_KEY: 签名用户登录令牌
# JWT_SECRET_KEY=your-jwt-key

# AES_KEY: 加密存储的数据库密码（必须 32 字符）
# AES_KEY=your-32-char-aes-key-here!!!!

# PASSWORD_SALT: 用户密码加密盐值
# PASSWORD_SALT=your-password-salt
